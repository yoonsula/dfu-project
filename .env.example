# All relative paths are resolved from this project folder (where paths.py lives).
# Copy to .env and uncomment as needed.

# --- Inference (defaults: bundled under assets/ + checkpoints/) ---
# DINOV3_REPO=assets/dinov3
# DINOV3_CHECKPOINT=assets/dinov3/checkpoint/dinov3_vits16_pretrain_lvd1689m-08c60483.pth
# DINOV3_HF_MODEL_DIR=assets/dinov3-hf/dinov3-vits16-pretrain-lvd1689m
# DFU_CHECKPOINT=checkpoints/best.pt
# DFU_CLASSIFICATION_CHECKPOINT=checkpoints/dinov3_linear_best_0.001.pt
# DFU_INFERENCE_OUTPUT_DIR=output/inference
# DFU_TRAIN_OUTPUT_DIR=output/train

# --- Training data (not bundled; only needed for train.py) ---
# DFU_DATA_ROOT=../데이터
# DFU_FOOT_ROOT=../데이터/roboflow-foot
# DFU_BODY_ROOT=../데이터/roboflow-body
# DFU_HUMANBODY_ROOT=../데이터/roboflow-humanbody
# DFU_ULCER_ROOT=../데이터/wound-segmentation/data/Foot Ulcer Segmentation Challenge
# DFU_WOUND_IMAGE_ROOT=../데이터/Wound Image Dataset
