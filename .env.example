# All relative paths are resolved from this project folder (where paths.py lives).
# Copy to .env and uncomment as needed.

# --- Inference (local Hugging Face backbone snapshot + head checkpoints) ---
# DINOV3_MODEL_PATH=assets/dinov3-hf
# DFU_CHECKPOINT_DIR=checkpoints
# DFU_INFERENCE_OUTPUT_DIR=output/inference
# DFU_TRAIN_OUTPUT_DIR=checkpoints

# --- Training data (not bundled; only needed for train.py) ---
# DFU_DATA_ROOT=../데이터
# DFU_FOOT_ROOT=../데이터/roboflow-foot
# DFU_BODY_ROOT=../데이터/roboflow-body
# DFU_HUMANBODY_ROOT=../데이터/roboflow-humanbody
# DFU_WOUND_ROOT=../데이터/wound-segmentation/data/Foot Ulcer Segmentation Challenge
# DFU_WOUND_IMAGE_ROOT=../데이터/Wound Image Dataset
# DFU_CLASSIFICATION_SOURCE_ROOT=../데이터/DFU Dataset
# DFU_PARTA_ROOT=../데이터/dfu_partA_20260617
# DFU_CLASSIFICATION_DATA_ROOT=../데이터/dfu_classification_data
